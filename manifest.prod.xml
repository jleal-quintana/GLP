<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="TaskPaneApp">
  <Id>6fd19b4b-12f0-4fb7-86fe-3eeb5efb7f20</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Quintana Energy</ProviderName>
  <DefaultLocale>es-AR</DefaultLocale>
  <DisplayName DefaultValue="GLP" />
  <Description DefaultValue="Add-in de Excel para descargar historico Capitulo IV, proyectar areas y generar graficos." />
  <IconUrl DefaultValue="https://jleal-quintana.github.io/GLP/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://jleal-quintana.github.io/GLP/assets/icon-80.png" />
  <SupportUrl DefaultValue="https://jleal-quintana.github.io/GLP/taskpane.html" />
  <AppDomains>
    <AppDomain>https://jleal-quintana.github.io</AppDomain>
    <AppDomain>https://datos.gob.ar</AppDomain>
    <AppDomain>http://datos.energia.gob.ar</AppDomain>
    <AppDomain>https://datos.energia.gob.ar</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Workbook" />
  </Hosts>
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="ExcelApi" MinVersion="1.10" />
    </Sets>
  </Requirements>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://jleal-quintana.github.io/GLP/taskpane.html" />
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title" />
            <Description resid="GetStarted.Description" />
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl" />
          </GetStarted>
          <FunctionFile resid="Commands.Url" />
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="CapIV.Group">
                <Label resid="CapIV.GroupLabel" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16" />
                  <bt:Image size="32" resid="Icon.32" />
                  <bt:Image size="80" resid="Icon.80" />
                </Icon>
                <Control xsi:type="Button" id="CapIV.ShowTaskpane">
                  <Label resid="CapIV.ButtonLabel" />
                  <Supertip>
                    <Title resid="CapIV.ButtonLabel" />
                    <Description resid="CapIV.ButtonDescription" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16" />
                    <bt:Image size="32" resid="Icon.32" />
                    <bt:Image size="80" resid="Icon.80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>CapIVTaskpane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16" DefaultValue="https://jleal-quintana.github.io/GLP/assets/icon-16.png" />
        <bt:Image id="Icon.32" DefaultValue="https://jleal-quintana.github.io/GLP/assets/icon-32.png" />
        <bt:Image id="Icon.80" DefaultValue="https://jleal-quintana.github.io/GLP/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://jleal-quintana.github.io/GLP/taskpane.html" />
        <bt:Url id="Commands.Url" DefaultValue="https://jleal-quintana.github.io/GLP/commands.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://jleal-quintana.github.io/GLP/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="GLP" />
        <bt:String id="CapIV.GroupLabel" DefaultValue="Quintana Energy" />
        <bt:String id="CapIV.ButtonLabel" DefaultValue="Abrir GLP" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Descarga historico Capitulo IV y arma proyecciones por area en Excel." />
        <bt:String id="CapIV.ButtonDescription" DefaultValue="Abre el panel para seleccionar areas, descargar datos, proyectar y generar graficos." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
